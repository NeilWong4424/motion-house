    "audio:mybola-v8": "python src/products/mybola/audio/make_audio.py MyBolaV8 --out out/audio",
    "audio:mybola-parent": "python src/products/mybola/audio/make_audio.py MyBolaParent --out out/audio"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
